entrypoint = "app.py"
modules = ["python-3.11"]

[nix]
channel = "stable-24_05"
packages = ["libiconv", "libxcrypt", "postgresql"]

[deployment]
run = ["python3", "app.py"]
deploymentTarget = "cloudrun"

[unitTest]
language = "python3"

[[ports]]
localPort = 8000
externalPort = 80

[agent]
expertMode = true